# Zoho Creator OAuth — get these from Zoho API Console
ZOHO_ACCESS_TOKEN=your_zoho_access_token
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REPORT_PRIVATELINK=

# Admin user deletion workflow (leave empty to use direct delete)
DELETE_USER_WORKFLOW_FORMS=
DELETE_USER_WORKFLOW_FIELD=ID1

# Property validation workflow configuration
ADMIN_PROPERTIES_REPORT_LINK_NAME=All_Properties
PROPERTY_VALIDATION_FIELD=Validation_Status
PROPERTY_PENDING_VALUE=pending
PROPERTY_APPROVED_VALUE=approved
PROPERTY_REJECTED_VALUE=rejected

# Property workflow forms (leave empty to use direct Zoho update/delete)
APPROVE_PROPERTY_WORKFLOW_FORMS=
APPROVE_PROPERTY_WORKFLOW_FIELD=Property_ID
REJECT_PROPERTY_WORKFLOW_FORMS=
REJECT_PROPERTY_WORKFLOW_FIELD=Property_ID
DELETE_PROPERTY_WORKFLOW_FORMS=
DELETE_PROPERTY_WORKFLOW_FIELD=Property_ID

# GROQ API Key — get from console.groq.com
GROQ_API_KEY=your_groq_api_key

# Email (password reset) — use Gmail App Password (not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=GI Immobilier <your-email@gmail.com>
APP_BASE_URL=http://localhost:3000
